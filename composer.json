{
    "name": "timejunky/grav-plugin-r4it-admin-plugin-boilerplate",
    "type": "grav-plugin",
    "description": "R4IT Admin Plugin Boilerplate for Grav CMS.",
    "homepage": "https://github.com/timejunky/r4it_admin-plugin_boilerplate_grav",
    "support": {
        "issues": "https://github.com/timejunky/r4it_admin-plugin_boilerplate_grav/issues",
        "source": "https://github.com/timejunky/r4it_admin-plugin_boilerplate_grav"
    },
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "grav/grav": ">=1.7.0",
        "grav/plugin-admin": ">=1.10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Grav\Plugin\R4itAdminPluginBoilerplate": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:integration": "phpunit --testsuite=integration"
    },
    "config": {
        "allow-plugins": {
            "getgrav/grav-plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "r4it_admin-plugin_boilerplate_grav": {
            "category": "Grav_Plugin",
            "author": "Nejat P. Eryigit <https://www.ready-4-it.com>",
            "copyright": "2026 Nejat P. Eryigit",
            "license": "https://opensource.org/licenses/MIT MIT License",
            "link": "https://github.com/timejunky/r4it_admin-plugin_boilerplate_grav"
        }
    }
}
