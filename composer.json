{
    "name": "r4it/grav-plugin-tool-boilerplate",
    "type": "grav-plugin",
    "description": "A boilerplate for Grav admin tool plugins.",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Grav\Plugin\R4itToolBoilerplate": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:integration": "phpunit --testsuite=integration"
    },
    "config": {
        "allow-plugins": {
            "getgrav/grav-plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
