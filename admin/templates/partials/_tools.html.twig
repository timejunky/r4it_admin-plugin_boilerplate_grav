<h3><i class="fa fa-flask"></i> {{ 'PLUGIN_R4IT_ADMIN_PLUGIN_BOILERPLATE.TOOLS_HEADING'|tu }}</h3>
<p>{{ 'PLUGIN_R4IT_ADMIN_PLUGIN_BOILERPLATE.TOOLS_INTRO'|tu }}</p>
<p>{{ 'PLUGIN_R4IT_ADMIN_PLUGIN_BOILERPLATE.TOOLS_TEXT_1'|tu }}</p>

{#
  Example tool action form.
  To wire this up:
    1. Add your task handler in the plugin: onAdminTaskRunBoilerplateTool() or via onTask.runBoilerplateTool
    2. Return a redirect or set a flash message in the task handler.
    3. Display the result below via a Twig variable injected by the controller.
#}
<form method="post" action="{{ tool_action_url|default(admin_route('r4it-admin-plugin-boilerplate')) }}">
    <input type="hidden" name="task" value="runBoilerplateTool" />
    {{ nonce_field('admin-form')|raw }}
    <div class="form-field">
        <label>{{ 'PLUGIN_R4IT_ADMIN_PLUGIN_BOILERPLATE.TOOLS_SAMPLE_ACTION_LABEL'|tu }}</label>
        <input type="text" name="tool_input" placeholder="{{ 'PLUGIN_R4IT_ADMIN_PLUGIN_BOILERPLATE.TOOLS_SAMPLE_ACTION_PLACEHOLDER'|tu }}" />
    </div>
    <div class="button-bar">
        <button type="submit" class="button primary">{{ 'PLUGIN_R4IT_ADMIN_PLUGIN_BOILERPLATE.TOOLS_RUN_BUTTON'|tu }}</button>
    </div>
</form>

{# Display task result if injected by the controller, e.g.: #}
